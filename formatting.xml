		<setting id="org.eclipse.jdt.core.formatter.insert_space_after_colon_in_labeled_statement" value="insert"/>
		<setting id="org.eclipse.jdt.core.formatter.insert_space_before_colon_in_case" value="do not insert"/>
		<setting id="org.eclipse.jdt.core.formatter.insert_space_before_colon_in_default" value="do not insert"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_then_statement_on_same_line" value="false"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_simple_if_on_one_line" value="false"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_else_statement_on_same_line" value="false"/>
		<setting id="org.eclipse.jdt.core.formatter.compact_else_if" value="true"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_simple_for_body_on_same_line" value="false"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_simple_while_body_on_same_line" value="false"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_simple_do_while_body_on_same_line" value="false"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_loop_body_block_on_one_line" value="one_line_never"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_if_then_body_block_on_one_line" value="one_line_never"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_lambda_body_block_on_one_line" value="one_line_never"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_code_block_on_one_line" value="one_line_never"/>

		<!-- ─── One-line collapsing ─────────────────────────────────────────────── -->

		<!-- Collapse empty method and constructor bodies onto one line.
		     one_line_if_empty: applies only when the body has no statements.
		     Non-empty bodies are unaffected and always expand normally.
		         before: public void close() {    after: public void close() { }
		                 }
		     Covers @Override stubs, AutoCloseable.close(), empty constructors, etc. -->
		<setting id="org.eclipse.jdt.core.formatter.keep_method_body_on_one_line" value="one_line_if_empty"/>

		<!-- Collapse empty record bodies onto one line.
		     A record with an empty body and components that fit within lineSplit
		     is collapsed entirely:
		         before: record FormatterProofSettings(   after: record FormatterProofSettings(
		                     String label,                           String label, int count,
		                     int count,                              Map<String, List<Integer>> groups,
		                     Map<String, List<Integer>> groups,      List<String> names) { }
		                     List<String> names) {
		                 }
		     If the components exceed lineSplit even on their own, the header still
		     wraps per alignment_for_record_components, but the body `{ }` collapses. -->
		<setting id="org.eclipse.jdt.core.formatter.keep_record_declaration_on_one_line" value="one_line_if_empty"/>

		<!-- Collapse empty record compact constructors onto one line.
		     Keeps parity with keep_record_declaration_on_one_line for the rare case
		     of an explicit compact constructor with an empty body. -->
		<setting id="org.eclipse.jdt.core.formatter.keep_record_constructor_on_one_line" value="one_line_if_empty"/>

		<!-- These remain never: non-empty type / enum / annotation declarations
		     should always expand; only empty method and record bodies collapse. -->
		<setting id="org.eclipse.jdt.core.formatter.keep_type_declaration_on_one_line" value="one_line_never"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_anonymous_type_declaration_on_one_line" value="one_line_never"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_enum_declaration_on_one_line" value="one_line_never"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_enum_constant_declaration_on_one_line" value="one_line_never"/>
		<setting id="org.eclipse.jdt.core.formatter.keep_annotation_declaration_on_one_line" value="one_line_never"/>

		<!-- ─── Line joining ────────────────────────────────────────────────────── -->
		<setting id="org.eclipse.jdt.core.formatter.join_wrapped_lines" value="true"/>
		<setting id="org.eclipse.jdt.core.formatter.wrap_outer_expressions_when_nested" value="true"/>

		<!-- ─── Alignment: compact/inline constructs ────────────────────────────── -->
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_compact_if" value="53"/>
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_compact_loops" value="53"/>

		<!-- ─── Alignment: arguments ────────────────────────────────────────────── -->
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_arguments_in_method_invocation" value="48"/>
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_arguments_in_allocation_expression" value="48"/>
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_arguments_in_annotation" value="48"/>

		<!-- ─── Alignment: parameters / declarations ────────────────────────────── -->
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_parameters_in_method_declaration" value="48"/>
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_parameters_in_constructor_declaration" value="48"/>
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_record_components" value="48"/>
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_resources_in_try" value="48"/>
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_expressions_in_array_initializer" value="48"/>

		<!-- ─── Alignment: method chain / selectors ─────────────────────────────── -->

		<!-- NEXT_PER_LINE + FORCE (81): force fluent chains to wrap, but keep the
		     receiver and first selector together. This directly targets the
		     multiline-lambda case while avoiding the uglier `Type` / `.method(...)`
		     split caused by ONE_PER_LINE + FORCE. -->
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_selector_in_method_invocation" value="81"/>

		<!-- Flat continuation indent: wrapped selectors align to the statement's
		     base indent + one continuation level, not to the receiver's column. -->
		<setting id="org.eclipse.jdt.core.formatter.align_selector_in_method_invocation_on_expression_first_line" value="false"/>

		<!-- ─── Alignment: inheritance / implements ─────────────────────────────── -->
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_superclass_in_type_declaration" value="16"/>
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_superinterfaces_in_type_declaration" value="16"/>
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_superinterfaces_in_enum_declaration" value="16"/>
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_superinterfaces_in_record_declaration" value="16"/>
		<setting id="org.eclipse.jdt.core.formatter.alignment_for_permitted_types_in_type_declaration" value="16"/>

